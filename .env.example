# Local development — copy to .env.local and fill in from `npx convex dev`
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional: stable share-link encoding in production (set as GitHub secret too)
# VITE_SHARE_OBFUSCATION_KEY=

# GitHub Pages subpath — set in deploy workflow automatically; override locally if needed
# VITE_BASE_PATH=/contracts/
